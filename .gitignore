# ──────────────────────────────────────────────────────────────
# PUBLIC / UPLOADS – IGNORE ALL FILES, KEEP ALL FOLDERS
# ──────────────────────────────────────────────────────────────
# Ignore every file (at any depth) inside public/uploads
public/uploads/**/*

# But keep every directory (so folder structure is in Git)
!public/uploads/**/

# Allow .gitkeep placeholders for empty folders
!public/uploads/**/.gitkeep

# ──────────────────────────────────────────────────────────────
# Optional: If you have other upload-like folders later
# ──────────────────────────────────────────────────────────────
# Example:
# storage/uploads/**/*
# !storage/uploads/**/
# !storage/uploads/**/.gitkeep